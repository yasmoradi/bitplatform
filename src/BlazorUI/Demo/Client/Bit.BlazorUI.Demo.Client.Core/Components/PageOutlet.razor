@inherits AppComponentBase

<PageTitle>@PageTitleText</PageTitle>

<HeadContent>
    <meta name="title" content="@PageTitleText" />
    <meta name="description" content="@MetaDescription" />
    <meta name="keywords" content="@MetaKeywords" />

    <meta property="og:url" content="@CanonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="bit BlazorUI" />
    <meta property="og:title" content="@PageTitleText" />
    <meta property="og:description" content="@MetaDescription" />
    <meta property="og:image" content="@ImageUrl" />
    <meta property="og:image:alt" content="@PageTitleText" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@@bitplatformhq" />
    <meta name="twitter:creator" content="@@bitplatformhq" />
    <meta name="twitter:title" content="@PageTitleText" />
    <meta name="twitter:description" content="@MetaDescription" />
    <meta name="twitter:image" content="@ImageUrl" />
    <meta name="twitter:image:alt" content="@PageTitleText" />

    <link rel="canonical" href="@CanonicalUrl" />

    @if (BreadcrumbJsonLd is not null)
    {
        @((MarkupString)BreadcrumbJsonLd)
    }
</HeadContent>

@code {
    private const string SiteBaseUrl = "https://blazorui.bitplatform.dev";

    // A concise (<160 chars) fallback used only when a page doesn't provide its own description.
    private const string DefaultDescription = "Native, easy-to-customize Blazor UI components that work seamlessly across WASM, Server, Hybrid and pre-rendering.";

    private const string BaseKeywords = "Blazor UI, Blazor components, Blazor WebAssembly UI, Blazor Server UI, Blazor Hybrid UI, .NET UI components, C# UI library, open source Blazor controls, Bit BlazorUI";

    [Parameter] public string? Url { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Keywords { get; set; }
    [Parameter] public string? Description { get; set; }

    // When set, this is used verbatim as the page/social title instead of the
    // "{Title} - bit BlazorUI" pattern. Useful for the home page where the
    // most valuable title slot should hold primary keywords rather than "Home".
    [Parameter] public string? FullTitle { get; set; }

    // Raster image for social cards (1200x630). Crawlers (Facebook, LinkedIn, X, Slack) don't render SVG,
    // so a PNG/JPG is required here. This dedicated og-image is shipped by the Core Razor Class Library and
    // is always served under the _content path regardless of the host project.
    [Parameter] public string ImageUrl { get; set; } = $"{SiteBaseUrl}/_content/Bit.BlazorUI.Demo.Client.Core/images/og-image.png";

    private string PageTitleText => FullTitle.HasValue() ? FullTitle! : $"{Title} - bit BlazorUI";

    private string CanonicalUrl => $"{SiteBaseUrl}/{Url?.ToLowerInvariant().TrimStart('/')}";

    private string MetaDescription => Description.HasValue() ? Description! : DefaultDescription;

    private string MetaKeywords => Keywords.HasValue() ? $"{BaseKeywords}, {Keywords}" : BaseKeywords;

    // Emits a BreadcrumbList structured-data block so search engines can render breadcrumb rich results.
    // The home page (empty Url) has no breadcrumb. Component pages get a "Components" crumb in between.
    private string? BreadcrumbJsonLd
    {
        get
        {
            var normalizedUrl = Url?.ToLowerInvariant().Trim('/');
            if (normalizedUrl.HasValue() is false) return null; // Home page: no breadcrumb.

            var leafName = Title.HasValue() ? Title! : normalizedUrl!;

            var items = new List<(string Name, string Url)>
            {
                ("Home", $"{SiteBaseUrl}/")
            };

            if (normalizedUrl!.StartsWith("components/"))
            {
                items.Add(("Components", $"{SiteBaseUrl}/components"));
            }

            items.Add((leafName, $"{SiteBaseUrl}/{normalizedUrl}"));

            var listElements = string.Join(",", items.Select((item, index) =>
                $"{{\"@type\":\"ListItem\",\"position\":{index + 1},\"name\":\"{JsonEscape(item.Name)}\",\"item\":\"{JsonEscape(item.Url)}\"}}"));

            return $"<script type=\"application/ld+json\">{{\"@context\":\"https://schema.org\",\"@type\":\"BreadcrumbList\",\"itemListElement\":[{listElements}]}}</script>";
        }
    }

    private static string JsonEscape(string value) => value.Replace("\\", "\\\\").Replace("\"", "\\\"");
}
