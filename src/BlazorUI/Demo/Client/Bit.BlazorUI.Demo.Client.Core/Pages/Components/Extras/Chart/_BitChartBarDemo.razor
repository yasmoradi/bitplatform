    <div class="chart-wrapper"><div class="chart-container"><BitChart RespectReducedMotion="false" Type="BitChartType.Bar" Data="@PerColor()" Options="@_horizontal" /></div></div>
</DemoExample>

<DemoExample Title="Rounded + per-bar colors" RazorCode="@roundedRazorCode" CsharpCode="@roundedCsharpCode" Id="bar-rounded">
