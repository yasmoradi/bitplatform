@namespace Bit.BlazorUI.Demo.Client.Core.Pages.Components.Extras.Chart

<DemoExample Title="Grouped" RazorCode="@groupedRazorCode" CsharpCode="@groupedCsharpCode" Id="bar-grouped">
    <div class="example-desc">three datasets side by side</div>
    <div class="chart-wrapper"><div class="chart-container"><BitChart RespectReducedMotion="false" Type="BitChartType.Bar" Data="BitChartSampleData.Revenue()" Options="_bottom" /></div></div>
</DemoExample>

<DemoExample Title="Stacked" RazorCode="@stackedRazorCode" CsharpCode="@stackedCsharpCode" Id="bar-stacked">
    <div class="example-desc">scales.y.stacked = true</div>
    <div class="chart-wrapper"><div class="chart-container"><BitChart RespectReducedMotion="false" Type="BitChartType.Bar" Data="BitChartSampleData.Revenue()" Options="@_stacked" /></div></div>
</DemoExample>

<DemoExample Title="Horizontal" RazorCode="@horizontalRazorCode" CsharpCode="@horizontalCsharpCode" Id="bar-horizontal">
