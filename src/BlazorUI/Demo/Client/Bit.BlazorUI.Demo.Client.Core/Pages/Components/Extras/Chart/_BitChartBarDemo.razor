    <div class="chart-wrapper"><div class="chart-container"><BitChart RespectReducedMotion="false" Type="BitChartType.Bar" Data="@PerColorRounded()" Options="@_rounded" /></div></div>
</DemoExample>

<DemoExample Title="Floating bars" RazorCode="@floatingRazorCode" CsharpCode="@floatingCsharpCode" Id="bar-floating">
