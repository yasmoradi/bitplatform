                <BitDataGridColumn Property="p => p.Id" Title="ID" Width="70px" Align="BitDataGridColumnAlign.Right" Filterable="false" Groupable="false" />
                <BitDataGridColumn Property="p => p.Name" Width="220px" Groupable="false" />
