        <BitButtonGroup Variant="BitVariant.Fill" Items="badgeCustoms" NameSelectors="badgeNameSelectors" />
        <BitButtonGroup Variant="BitVariant.Outline" Items="badgeCustoms" NameSelectors="badgeNameSelectors" />
