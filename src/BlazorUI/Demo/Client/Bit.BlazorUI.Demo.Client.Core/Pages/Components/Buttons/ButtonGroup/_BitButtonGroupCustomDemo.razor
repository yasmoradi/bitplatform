<DemoExample Title="Style &amp; Class" RazorCode="@example24RazorCode" CsharpCode="@example24CsharpCode" Id="example24" PreventRenderForMcpClient>
    <div>
        Styling works at three levels: <strong>Style</strong> and <strong>Class</strong> target the root element, the
        <strong>Style</strong> and <strong>Class</strong> selectors target a single button through fields on the class, and
        <strong>Styles</strong> and <strong>Classes</strong> reach every part of the component — Root, Button,
        ToggledButton, Icon, Text, Badge, Spinner, and SelectionIndicator.
    </div>
    <br /><br />
    <div class="example-content">
        <div>Component's style & class:</div>
        <BitButtonGroup Items="basicCustoms" Style="border-radius: 1rem; margin: 1rem; box-shadow: tomato 0 0 1rem;" NameSelectors="nameSelector" />
        <BitButtonGroup Items="basicCustoms" Class="custom-class" Variant="BitVariant.Outline" NameSelectors="nameSelector" />
    </div>
    <br /><br />
    <div class="example-content">
        <div>Item's style & class:</div>
        <BitButtonGroup Items="styleClassCustoms"
                        Variant="BitVariant.Text"
                        NameSelectors="@(new() { Text = { Selector = i => i.Name },
                                                 IconName = { Selector = i => i.Image } })" />
    </div>
    <br /><br />
    <div class="example-content">
        <div><b>Styles</b> & <b>Classes</b>:</div>
        <BitButtonGroup Items="basicCustoms"
                        Variant="BitVariant.Text"
                        NameSelectors="nameSelector"
                        Styles="@(new() { Button = "color: darkcyan; border-color: deepskyblue; background-color: azure;" })" />

        <BitButtonGroup Items="basicCustoms"
                        Variant="BitVariant.Text"
                        NameSelectors="nameSelector"
                        Classes="@(new() { Button = "custom-btn" })" />
    </div>
</DemoExample>

