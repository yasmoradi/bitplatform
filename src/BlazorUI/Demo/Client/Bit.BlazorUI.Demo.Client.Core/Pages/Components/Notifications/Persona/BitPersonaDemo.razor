    <DemoExample Title="AutoCoinColor" RazorCode="@example12RazorCode" Id="example12">
        <div>Different people each get a distinct, consistent coin color automatically:</div>
        <br />
        <BitPersona AutoCoinColor PrimaryText="Xafan Salina" SecondaryText="Software Engineer" Size="BitPersonaSize.Size72" />
        <br /><br />
        <BitPersona AutoCoinColor PrimaryText="Saleh Khafan" SecondaryText="Developer" Size="BitPersonaSize.Size72" />
        <br /><br />
        <BitPersona AutoCoinColor PrimaryText="Ted Randall" SecondaryText="Designer" Size="BitPersonaSize.Size72" />
        <br /><br />
        <BitPersona AutoCoinColor PrimaryText="Carlos Slattery" SecondaryText="Manager" Size="BitPersonaSize.Size72" />
        <br /><br />
        <BitPersona AutoCoinColor PrimaryText="Elvia Atkins" SecondaryText="QA Engineer" Size="BitPersonaSize.Size72" />
        <br /><br /><br /><br />
        <div>Custom ImageInitials also influence the generated color:</div>
        <br />
        <BitPersona AutoCoinColor ImageInitials="ZZ" PrimaryText="Xafan Salina" SecondaryText="Software Engineer" Size="BitPersonaSize.Size72" />
        <br /><br /><br /><br />
        <div>CoinColor takes precedence over AutoCoinColor when set explicitly:</div>
        <br />
        <BitPersona AutoCoinColor CoinColor="BitColor.Success" PrimaryText="Xafan Salina" SecondaryText="Always green" Size="BitPersonaSize.Size72" />
    </DemoExample>

    <DemoExample Title="Image Events" RazorCode="@example13RazorCode" CsharpCode="@example13CsharpCode" Id="example13">
        <div>OnImageLoad - callback invoked when the image loads successfully:</div>
        <br />
        <BitPersona PrimaryText="Xafan Salina"
                    SecondaryText="Software Engineer"
                    Size="BitPersonaSize.Size72"
                    OnImageLoad="() => imageLoadCount++"
                    ImageUrl="/_content/Bit.BlazorUI.Demo.Client.Core/images/persona/persona-female.png" />
        <br />
        <p>Image Load Count: @imageLoadCount</p>
        <br /><br /><br /><br />
        <div>OnImageError - callback invoked when the image fails to load:</div>
        <br />
        <BitPersona PrimaryText="Xafan Salina"
                    SecondaryText="Software Engineer"
                    Size="BitPersonaSize.Size72"
                    OnImageError="() => imageErrorCount++"
                    ImageUrl="invalid-image-url" />
        <br />
        <p>Image Error Count: @imageErrorCount</p>
    </DemoExample>

    <DemoExample Title="ImageLoading" RazorCode="@example14RazorCode" Id="example14">
