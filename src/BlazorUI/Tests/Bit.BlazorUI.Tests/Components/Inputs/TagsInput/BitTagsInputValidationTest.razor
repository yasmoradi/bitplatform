<EditForm Model="@TestModel" OnValidSubmit="@HandleValidSubmit" OnInvalidSubmit="@HandleInvalidSubmit">
    <DataAnnotationsValidator />

    <BitTagsInput IsEnabled="IsEnabled"
                  Placeholder="@Placeholder"
                  @bind-Value="@TestModel.Tags" />

</EditForm>

@code {
    [Parameter] public BitTagsInputTestModel TestModel { get; set; } = new();
    [Parameter] public string? Placeholder { get; set; }
    [Parameter] public bool IsEnabled { get; set; } = true;

    public int ValidCount { get; set; }
    public int InvalidCount { get; set; }

    private void HandleValidSubmit()
    {
        ValidCount++;
    }

    private void HandleInvalidSubmit()
    {
        InvalidCount++;
    }
}
