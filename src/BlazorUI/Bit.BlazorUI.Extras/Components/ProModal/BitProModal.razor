@namespace Bit.BlazorUI
@inherits BitComponentBase

<BitModal AriaLabel="@AriaLabel"
          AriaModal="Modeless is false"
          Class="@ClassBuilder.Value"
          Dir="Dir"
          @attributes="HtmlAttributes"
          Id="@_modalId"
          IsEnabled="IsEnabled"
          Style="@StyleBuilder.Value"
          Visibility="Visibility"
          Blocking="Blocking"
          Classes="Classes"
          FullHeight="FullHeight || FullSize"
          FullWidth="FullWidth || FullSize"
          IsAlert="@(IsAlert ?? (Blocking && Modeless is false))"
          IsOpen="IsOpen"
          IsOpenChanged="HandleInnerIsOpenChanged"
          OnDismiss="OnDismiss"
          OnOverlayClick="OnOverlayClick"
          ShowOverlay="Modeless is false"
          SubtitleAriaId="@SubtitleAriaId"
          TitleAriaId="@TitleAriaId"
          Styles="Styles">
    @if (Header is not null || HeaderText is not null || ShowCloseButton)
    {
        <div style="@Styles?.HeaderContainer" class="bit-pmd-hcn @Classes?.HeaderContainer">
            @if (Header is not null)
            {
                <div style="@Styles?.Header" class="bit-pmd-hdr @Classes?.Header">
                    @Header
                </div>
            }
            else if (HeaderText is not null)
            {
                <div style="@Styles?.Header" class="bit-pmd-hdr @Classes?.Header">
                    @HeaderText
                </div>
            }

            @if (ShowCloseButton)
            {
                var closeIcon = BitIconInfo.From(CloseIcon, CloseIconName ?? "Cancel");

                <button @onclick="CloseModal"
                        type="button"
                        title="@CloseButtonTitle"
                        aria-label="@CloseButtonTitle"
                        style="@Styles?.CloseButton"
                        class="bit-pmd-cls @Classes?.CloseButton">
                    <i style="@Styles?.CloseIcon"
                       class="@closeIcon?.GetCssClasses() @Classes?.CloseIcon" />
                </button>
            }
        </div>
    }

    <div style="@Styles?.Body" class="bit-pmd-bdy @Classes?.Body">
        @(Body ?? ChildContent)
    </div>

    @if (Footer is not null)
    {
        <div style="@Styles?.Footer" class="bit-pmd-fcn @Classes?.Footer">
            @Footer
        </div>
    }
    else if (FooterText is not null)
    {
        <div style="@Styles?.Footer" class="bit-pmd-fcn @Classes?.Footer">
            @FooterText
        </div>
    }
</BitModal>
