@namespace Bit.BlazorUI
@inherits BitComponentBase

@if (IsOpen)
{
    <div @ref="RootElement" @attributes="_params.HtmlAttributes"
         id="@_Id"
         style="@StyleBuilder.Value"
         class="@ClassBuilder.Value"
         dir="@_params.Dir?.ToString().ToLower()"
         aria-labelledby="@_params.TitleAriaId"
         aria-describedby="@_params.SubtitleAriaId"
         aria-modal="@((_params.AriaModal ?? true).ToString().ToLowerInvariant())"
         role="@GetRole()">
        @if (_params.ShowOverlay ?? true)
        {
            <div @onclick="HandleOnOverlayClick"
                 aria-hidden="true"
                 style="@Styles?.Overlay @_params.Styles?.Overlay"
                 class="bit-mdl-ovl @Classes?.Overlay @_params.Classes?.Overlay" />
        }
        <div id="@_containerId"
             style="@($"{Styles?.Content} {_params.Styles?.Content}".Trim())"
             class="@($"bit-mdl-ctn {Classes?.Content} {_params.Classes?.Content}".Trim())">
            @ChildContent
        </div>
    </div>
}
