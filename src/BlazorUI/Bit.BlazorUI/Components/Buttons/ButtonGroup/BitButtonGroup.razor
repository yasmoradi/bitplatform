@namespace Bit.BlazorUI
@inherits BitComponentBase
@typeparam TItem

<div @ref="RootElement" @attributes="HtmlAttributes" @onkeydown="HandleOnKeyDown" @onkeydown:preventDefault="_preventKeyDownDefault"
     id="@_Id"
     role="@_RootRole"
     style="@StyleBuilder.Value"
     class="@ClassBuilder.Value"
     dir="@Dir?.ToString().ToLower()"
     aria-label="@AriaLabel"
     aria-orientation="@_AriaOrientation">
    @if (Options is not null || ChildContent is not null)
    {
        <CascadingValue Value="this" IsFixed="true">
            @(Options ?? ChildContent)
        </CascadingValue>
    }
    else
    {
        @for (int i = 0; i < _items.Count; i++)
        {
            var item = _items[i];
            <_BitButtonGroupItem @key="@(GetItemKey(item) ?? $"{UniqueId}-{i}")" ButtonGroup="this" Item="item" />
        }
    }
</div>
