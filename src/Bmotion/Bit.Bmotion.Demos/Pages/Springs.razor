@page "/springs"

<h1>Springs</h1>

<div class="demo-section">
    <h2>Spring Physics</h2>
    <p>
        Use <strong>Bm.Spring(...)</strong> for physically-based motion.
        Tune <em>stiffness</em> (snap speed) and <em>damping</em> (oscillation).
    </p>

    <div class="demo-row">
        @foreach (var cfg in _springs)
        {
            <div class="demo-card" style="flex-direction:column; gap:.75rem;">
                <span style="font-size:.78rem; color:#888">@cfg.Label</span>
                <Bmotion Animate="@(_on ? Bm.To(x: 80) : Bm.To(x: 0))"
                        Transition="@cfg.Config">
                    <div class="box box-sm" />
                </Bmotion>
            </div>
        }
    </div>

    <button class="btn-bm" style="margin-top:1rem" @onclick="@(() => _on = !_on)">
        Animate
    </button>

    <CodeSnippet Code="@_springCode" />
</div>

<div class="demo-section">
    <h2>Bouncy Enter</h2>
    <p>Underdamped springs produce delightful overshoots on mount.</p>
    <div class="demo-row">
        <div class="demo-card">
            <Bmotion Initial="Bm.To(scale: 0, rotate: -180)"
                    Animate="Bm.To(scale: 1, rotate: 0)"
                    Transition="Bm.Spring(stiffness: 260, damping: 12)"
                    @key="@_mountKey">
                <div class="box" />
            </Bmotion>
        </div>
    </div>
    <button class="btn-bm" style="margin-top:1rem" @onclick="Remount">Re-mount</button>

    <CodeSnippet Code="@_bouncyCode" />
</div>

<div class="demo-section">
    <h2>Repeating Springs</h2>
    <p>
        Springs now honour <strong>repeat</strong> via <strong>BmRepeat</strong>.
        <em>Mirror</em> ping-pongs back to the start, <em>Loop</em> replays from the origin.
    </p>

    <div class="demo-row">
        <div class="demo-card" style="flex-direction:column; gap:.75rem;">
            <span style="font-size:.78rem; color:#888">Mirror &middot; infinite</span>
            <Bmotion Animate="@(_repeat ? Bm.To(x: 90) : Bm.To(x: 0))"
                    Transition="Bm.Spring(stiffness: 200, damping: 12, repeat: BmRepeat.Mirror())">
                <div class="box box-sm" />
            </Bmotion>
        </div>

        <div class="demo-card" style="flex-direction:column; gap:.75rem;">
            <span style="font-size:.78rem; color:#888">Loop &middot; 3&times; with delay</span>
            <Bmotion Animate="@(_repeat ? Bm.To(y: 60) : Bm.To(y: 0))"
                    Transition="Bm.Spring(stiffness: 300, damping: 18, repeat: BmRepeat.Loop(3, delay: 0.3))">
                <div class="box box-sm" />
            </Bmotion>
        </div>
    </div>

    <button class="btn-bm" style="margin-top:1rem" @onclick="@(() => _repeat = !_repeat)">
        @(_repeat ? "Reset" : "Start repeating")
    </button>

    <CodeSnippet Code="@_repeatCode" />
</div>

@code {
    private bool _on;
    private bool _repeat;
    private int  _mountKey;

    private record SpringDemo(string Label, BmTransition Config);

    private readonly SpringDemo[] _springs =
    [
        new("Stiff 400 / Damp 40",  Bm.Spring(400, 40)),
        new("Stiff 100 / Damp 10",  Bm.Spring(100, 10)),
        new("Stiff 50 / Damp 5",    Bm.Spring(50,  5)),
        new("Stiff 300 / Damp 70",  Bm.Spring(300, 70)),
    ];

    void Remount() => _mountKey++;

    private const string _springCode = """
        @using Bit.Bmotion

        <style>
            :root {
                --bm-primary: #6c47ff; --bm-secondary: #ff4785;
                --bm-card: #1e1e2e; --bm-muted: #888; --bm-radius: 12px;
            }
            .demo-section { margin-bottom: 3rem; }
            .demo-section h2 { font-size: 1.4rem; font-weight: 700; margin-bottom: .5rem; }
            .demo-row { display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: center; }
            .demo-card {
                background: var(--bm-card); border: 1px solid rgba(255,255,255,.07);
                border-radius: var(--bm-radius); padding: 2rem; min-height: 160px; flex: 1;
                min-width: 220px; display: flex; align-items: center; justify-content: center;
            }
            .box-sm {
                width: 50px; height: 50px; border-radius: 8px;
                background: linear-gradient(135deg, var(--bm-primary), var(--bm-secondary));
            }
            .btn-bm {
                background: var(--bm-primary); color: #fff; border: none; border-radius: 8px;
                padding: .6rem 1.4rem; font-weight: 600; cursor: pointer;
            }
        </style>

        <div class="demo-section">
            <h2>Spring Physics</h2>

            <div class="demo-row">
                @foreach (var cfg in _springs)
                {
                    <div class="demo-card" style="flex-direction:column; gap:.75rem;">
                        <span style="font-size:.78rem; color:#888">@cfg.Label</span>
                        <Bmotion Animate="@(_on ? Bm.To(x: 80) : Bm.To(x: 0))"
                                Transition="@cfg.Config">
                            <div class="box box-sm" />
                        </Bmotion>
                    </div>
                }
            </div>

            <button class="btn-bm" style="margin-top:1rem" @onclick="@(() => _on = !_on)">
                Animate
            </button>
        </div>

        @code {
            private bool _on;

            private record SpringDemo(string Label, BmTransition Config);

            private readonly SpringDemo[] _springs =
            [
                new("Stiff 400 / Damp 40",  Bm.Spring(400, 40)),
                new("Stiff 100 / Damp 10",  Bm.Spring(100, 10)),
                new("Stiff 50 / Damp 5",    Bm.Spring(50,  5)),
                new("Stiff 300 / Damp 70",  Bm.Spring(300, 70)),
            ];
        }
        """;

    private const string _bouncyCode = """
        @using Bit.Bmotion

        <style>
            :root { --bm-primary: #6c47ff; --bm-secondary: #ff4785; --bm-card: #1e1e2e; --bm-muted: #888; }
            .demo-section { margin-bottom: 3rem; }
            .demo-section h2 { font-size: 1.4rem; font-weight: 700; margin-bottom: .5rem; }
            .demo-section p { color: var(--bm-muted); margin-bottom: 1.5rem; line-height: 1.6; }
            .demo-row { display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: center; }
            .demo-card {
                background: var(--bm-card); border: 1px solid rgba(255,255,255,.07);
                border-radius: 12px; padding: 2rem; min-height: 160px; flex: 1; min-width: 220px;
                display: flex; align-items: center; justify-content: center;
            }
            .box {
                width: 80px; height: 80px; border-radius: 10px;
                background: linear-gradient(135deg, var(--bm-primary), var(--bm-secondary));
            }
            .btn-bm {
                background: var(--bm-primary); color: #fff; border: none; border-radius: 8px;
                padding: .6rem 1.4rem; font-weight: 600; cursor: pointer;
            }
        </style>

        <div class="demo-section">
            <h2>Bouncy Enter</h2>
            <p>Underdamped springs produce delightful overshoots on mount.</p>
            <div class="demo-row">
                <div class="demo-card">
                    <Bmotion Initial="Bm.To(scale: 0, rotate: -180)"
                            Animate="Bm.To(scale: 1, rotate: 0)"
                            Transition="Bm.Spring(stiffness: 260, damping: 12)"
                            @key="@_mountKey">
                        <div class="box" />
                    </Bmotion>
                </div>
            </div>
            <button class="btn-bm" style="margin-top:1rem" @onclick="Remount">Re-mount</button>
        </div>

        @code {
            private int _mountKey;

            void Remount() => _mountKey++;
        }
        """;

    private const string _repeatCode = """
        @using Bit.Bmotion

        <style>
            :root { --bm-primary: #6c47ff; --bm-secondary: #ff4785; --bm-card: #1e1e2e; }
            .demo-section { margin-bottom: 3rem; }
            .demo-section h2 { font-size: 1.4rem; font-weight: 700; margin-bottom: .5rem; }
            .demo-row { display: flex; flex-wrap: wrap; gap: 1.5rem; align-items: center; }
            .demo-card {
                background: var(--bm-card); border: 1px solid rgba(255,255,255,.07);
                border-radius: 12px; padding: 2rem; min-height: 160px; flex: 1; min-width: 220px;
                display: flex; align-items: center; justify-content: center;
            }
            .box-sm {
                width: 50px; height: 50px; border-radius: 8px;
                background: linear-gradient(135deg, var(--bm-primary), var(--bm-secondary));
            }
            .btn-bm {
                background: var(--bm-primary); color: #fff; border: none; border-radius: 8px;
                padding: .6rem 1.4rem; font-weight: 600; cursor: pointer;
            }
        </style>

        <div class="demo-section">
            <h2>Repeating Springs</h2>

            <div class="demo-row">
                <div class="demo-card" style="flex-direction:column; gap:.75rem;">
                    <span style="font-size:.78rem; color:#888">Mirror &middot; infinite</span>
                    <Bmotion Animate="@(_repeat ? Bm.To(x: 90) : Bm.To(x: 0))"
                            Transition="Bm.Spring(stiffness: 200, damping: 12, repeat: BmRepeat.Mirror())">
                        <div class="box box-sm" />
                    </Bmotion>
                </div>

                <div class="demo-card" style="flex-direction:column; gap:.75rem;">
                    <span style="font-size:.78rem; color:#888">Loop &middot; 3&times; with delay</span>
                    <Bmotion Animate="@(_repeat ? Bm.To(y: 60) : Bm.To(y: 0))"
                            Transition="Bm.Spring(stiffness: 300, damping: 18, repeat: BmRepeat.Loop(3, delay: 0.3))">
                        <div class="box box-sm" />
                    </Bmotion>
                </div>
            </div>

            <button class="btn-bm" style="margin-top:1rem" @onclick="@(() => _repeat = !_repeat)">
                @(_repeat ? "Reset" : "Start repeating")
            </button>
        </div>

        @code {
            private bool _repeat;
        }
        """;
}
