<header class="bb-header">
    <div class="bb-header-inner">
        <BrouterLink Href="/" Match="BrouterLinkMatch.All" class="bb-brand">
            <span class="bb-brand-text">Bit.Brouter</span>
            <span class="bb-brand-tag">demo</span>
        </BrouterLink>

        <nav class="bb-nav">
            <BrouterLink Href="/" Match="BrouterLinkMatch.All">Home</BrouterLink>
            @* BrouterRoutes.* are compile-time-safe URL builders generated by Bit.Brouter.Generators
               from this project's @page directives and <Broute> declarations. *@
            <BrouterLink Href="@BrouterRoutes.Counter(1234)">Counter</BrouterLink>
            <BrouterLink Href="@BrouterRoutes.Fetchdata()">Fetch data</BrouterLink>
            <BrouterLink Href="@BrouterRoutes.ProfileByUsername()">Profile</BrouterLink>
            <BrouterLink Href="/posts/2024/12/hello-world">Posts</BrouterLink>
            <BrouterLink Href="/nested">Nested</BrouterLink>
            <BrouterLink Href="/g1">Guarded</BrouterLink>
            <BrouterLink Href="/discovered/1?q=hello">Discovered</BrouterLink>
            <BrouterLink Href="@BrouterRoutes.Data()" Preload="BrouterLinkPreload.Intent">Data</BrouterLink>
            <BrouterLink Href="/dashboard/stats">Dashboard</BrouterLink>
        </nav>
    </div>
</header>
