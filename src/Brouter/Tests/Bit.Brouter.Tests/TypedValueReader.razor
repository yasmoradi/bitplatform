@* No Name on the cascading parameters: the wrapper types are unique, so type-based matching suffices. *@
<div data-testid="name">@(Data?.Get<LoadedUser>().Name)</div>
<div data-testid="age">@(Data?.Get<LoadedUser>().Age)</div>
<div data-testid="meta">@(Meta?.GetOrDefault<string>())</div>

@code {
    [CascadingParameter] public BrouterRouteData? Data { get; set; }
    [CascadingParameter] public BrouterRouteMeta? Meta { get; set; }
}
