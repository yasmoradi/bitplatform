@using Bit.Brouter

<Brouter NotFound="/404">
    <BrouterRoute Path="/secret" Guard="@Deny">
        <Content><div data-testid="ok">should not render</div></Content>
    </BrouterRoute>
    <BrouterRoute Path="/login">
        <Content><div data-testid="login">login</div></Content>
    </BrouterRoute>
    <BrouterRoute Path="/404">
        <Content>404</Content>
    </BrouterRoute>
</Brouter>

@code {
    private ValueTask Deny(BrouterNavigationContext ctx)
    {
        ctx.Redirect("/login");
        return ValueTask.CompletedTask;
    }
}
