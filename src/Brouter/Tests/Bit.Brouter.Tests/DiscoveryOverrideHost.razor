@* Hand-declares a route with the exact template of the attribute-discovered DiscoveredPage
   (@page "/discovered/{id:int}"). This is the documented override pattern: the hand-declared
   route registers first, wins the order tie, and must NOT be rejected as ambiguous. *@
@using Bit.Brouter

<Brouter AppAssembly="@typeof(DiscoveryOverrideHost).Assembly">
    <Broute Path="/discovered/{id:int}">
        <Content><div data-testid="override">override</div></Content>
    </Broute>
</Brouter>
