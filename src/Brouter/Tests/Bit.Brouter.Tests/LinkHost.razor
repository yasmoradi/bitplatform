@* Hosts a Brouter together with a single configurable BrouterLink so BrouterLinkTests can
   exercise active-state matching and click handling against a real navigation pipeline. *@

@using Bit.Brouter

<Brouter>
    <Broute Path="/*">
        <Content><div data-testid="content">page</div></Content>
    </Broute>
</Brouter>

<BrouterLink Href="@Href" Match="@Match" Class="@Class" ActiveClass="@ActiveClass"
             Replace="@Replace" data-testid="link">
    link
</BrouterLink>

@code {
    [Parameter] public string Href { get; set; } = "/";
    [Parameter] public BrouterLinkMatch Match { get; set; } = BrouterLinkMatch.Prefix;
    [Parameter] public string? Class { get; set; }
    [Parameter] public string ActiveClass { get; set; } = "active";
    [Parameter] public bool Replace { get; set; }
}
