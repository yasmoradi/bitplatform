@page "/location"
@inject Bit.Butil.Location location

<PageTitle>Butil - Location Samples</PageTitle>

<PageHeader Category="Navigation"
            Title="Location"
            Lead="Read and manipulate every part of the current URL - protocol, host, path, query and hash - and trigger navigation, assignment, replacement or a reload."
            MdnUrl="https://developer.mozilla.org/en-US/docs/Web/API/Location" />

<pre>
@@inject Bit.Butil.Location location

var href = await location.GetHref();
await location.SetHash("#section-2");
await location.Reload();
</pre>

<p class="muted" style="margin-top:1rem">⚠️ Setting Href, Host, Pathname, Assign or Replace will navigate away from this page.</p>

<div class="stack" style="margin-top:1rem">
    <DemoCard Title="URL parts" Api="Get* / Set*"
              Description="Read or change individual pieces of the URL. Get is safe; Set updates the address bar and may navigate.">
        @foreach (var part in Parts)
        {
            <div class="inline-field" style="margin-bottom:.6rem">
                <input @bind="part.Value" placeholder="@($"new {part.Name}")" />
                <button @onclick="() => part.Set(part.Value)">Set @part.Name</button>
                <button class="secondary" @onclick="() => part.Get()">Get @part.Name</button>
            </div>
        }
    </DemoCard>

    <DemoCard Title="Origin" Api="GetOrigin"
              Description="The read-only origin (scheme + host + port) of the current URL.">
        <button @onclick=GetOrigin>GetOrigin</button>
    </DemoCard>

    <DemoCard Title="Navigate" Api="Assign / Replace / Reload"
              Description="Assign loads a new URL (keeping history); Replace loads without a history entry; Reload re-fetches the current page.">
        <div class="inline-field" style="margin-bottom:.6rem">
            <input @bind="newAssign" placeholder="URL to assign" />
            <button @onclick=SetAssign>Assign</button>
        </div>
        <div class="inline-field" style="margin-bottom:.6rem">
            <input @bind="newReplace" placeholder="URL to replace with" />
            <button @onclick=SetReplace>Replace</button>
        </div>
        <button class="danger" @onclick="@(() => location.Reload())">Reload</button>
    </DemoCard>
</div>

<DemoConsole @ref="output" Title="location output" />

@code {
    private DemoConsole output = default!;

    private string newAssign;
    private string newReplace;

    private List<UrlPart> Parts = default!;

    protected override void OnInitialized()
    {
        Parts =
        [
            new("href",     v => location.SetHref(v),     () => location.GetHref(),     v => Log("href", v)),
            new("protocol", v => location.SetProtocol(v), () => location.GetProtocol(), v => Log("protocol", v)),
            new("host",     v => location.SetHost(v),     () => location.GetHost(),     v => Log("host", v)),
            new("hostname", v => location.SetHostname(v), () => location.GetHostname(), v => Log("hostname", v)),
            new("port",     v => location.SetPort(v),     () => location.GetPort(),     v => Log("port", v)),
            new("pathname", v => location.SetPathname(v), () => location.GetPathname(), v => Log("pathname", v)),
            new("search",   v => location.SetSearch(v),   () => location.GetSearch(),   v => Log("search", v)),
            new("hash",     v => location.SetHash(v),     () => location.GetHash(),     v => Log("hash", v)),
        ];
    }

    private Task Log(string name, string value) => output.Success($"location.{name} →", value);

    private async Task GetOrigin()
    {
        await output.Success("location.origin →", await location.GetOrigin());
    }

    private async Task SetAssign()
    {
        await location.Assign(newAssign);
        await output.Log("Assign →", newAssign);
    }

    private async Task SetReplace()
    {
        await location.Replace(newReplace);
        await output.Log("Replace →", newReplace);
    }

    private class UrlPart
    {
        public string Name { get; }
        public string Value { get; set; } = "";
        private readonly Func<string, Task> _set;
        private readonly Func<Task<string>> _get;
        private readonly Func<string, Task> _log;

        public UrlPart(string name, Func<string, Task> set, Func<Task<string>> get, Func<string, Task> log)
        {
            Name = name;
            _set = set;
            _get = get;
            _log = log;
        }

        public async Task Set(string value)
        {
            await _set(value);
            await _log(value);
        }

        public async Task Get()
        {
            await _log(await _get());
        }
    }
}
