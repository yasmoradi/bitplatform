@page "/visualViewport"
@implements IAsyncDisposable
@inject Bit.Butil.VisualViewport visualViewport

<PageTitle>Butil - VisualViewport Samples</PageTitle>

<PageHeader Category="Browser & Device"
            Title="VisualViewport"
            Lead="Inspect the visual viewport - the part of the page actually visible - including its offset, size and pinch-zoom scale. Especially useful on mobile with the on-screen keyboard."
            MdnUrl="https://developer.mozilla.org/en-US/docs/Web/API/VisualViewport" />

<pre>
@@inject Bit.Butil.VisualViewport visualViewport

var scale     = await visualViewport.GetScale();
var offsetTop = await visualViewport.GetOffsetTop();
</pre>

<div class="stack" style="margin-top:1.5rem">
    <DemoCard Title="Offset" Api="GetOffsetLeft / GetOffsetTop"
              Description="The viewport's offset from the layout viewport.">
        <div class="controls">
            <button @onclick="GetOffsetLeft">OffsetLeft</button>
            <button @onclick="GetOffsetTop">OffsetTop</button>
        </div>
    </DemoCard>

    <DemoCard Title="Page position" Api="GetPageLeft / GetPageTop"
              Description="The viewport's position relative to the document.">
        <div class="controls">
            <button @onclick="GetPageLeft">PageLeft</button>
            <button @onclick="GetPageTop">PageTop</button>
        </div>
    </DemoCard>

    <DemoCard Title="Size & scale" Api="GetWidth / GetHeight / GetScale"
              Description="The viewport's dimensions and the current pinch-zoom scale.">
        <div class="controls">
            <button @onclick="GetWidth">Width</button>
            <button @onclick="GetHeight">Height</button>
            <button @onclick="GetScale">Scale</button>
        </div>
    </DemoCard>

    <DemoCard Title="Live events" Api="SubscribeResize / SubscribeScroll"
              Description="Subscribe to resize and scroll events - pinch-zoom or scroll the page to see updates.">
        <div class="controls">
            <button @onclick="SubscribeResize">Subscribe resize</button>
            <button @onclick="SubscribeScroll">Subscribe scroll</button>
            <button class="danger" @onclick="UnsubscribeAll">Unsubscribe all</button>
        </div>
    </DemoCard>
</div>

<DemoConsole @ref="output" Title="visualViewport output" />

@code {
    private DemoConsole output = default!;
    private ButilSubscription? _resizeSub;
    private ButilSubscription? _scrollSub;

    private async Task GetOffsetLeft()
    {
        await output.Success("OffsetLeft →", await visualViewport.GetOffsetLeft());
    }

    private async Task GetOffsetTop()
    {
        await output.Success("OffsetTop →", await visualViewport.GetOffsetTop());
    }

    private async Task GetPageLeft()
    {
        await output.Success("PageLeft →", await visualViewport.GetPageLeft());
    }

    private async Task GetPageTop()
    {
        await output.Success("PageTop →", await visualViewport.GetPageTop());
    }

    private async Task GetWidth()
    {
        await output.Success("Width →", await visualViewport.GetWidth());
    }

    private async Task GetHeight()
    {
        await output.Success("Height →", await visualViewport.GetHeight());
    }

    private async Task GetScale()
    {
        await output.Success("Scale →", await visualViewport.GetScale());
    }

    private async Task SubscribeResize()
    {
        await UnsubscribeResize();
        _resizeSub = await visualViewport.SubscribeResize(async () =>
        {
            var w = await visualViewport.GetWidth();
            var h = await visualViewport.GetHeight();
            await output.Log($"Resize → {w:F0}×{h:F0}, scale={await visualViewport.GetScale():F2}");
        });
        await output.Log("Subscribed to resize.");
    }

    private async Task SubscribeScroll()
    {
        await UnsubscribeScroll();
        _scrollSub = await visualViewport.SubscribeScroll(async () =>
        {
            await output.Log($"Scroll → offset=({await visualViewport.GetOffsetLeft():F0}, {await visualViewport.GetOffsetTop():F0})");
        });
        await output.Log("Subscribed to scroll.");
    }

    private async Task UnsubscribeAll()
    {
        await UnsubscribeResize();
        await UnsubscribeScroll();
        await output.Log("All subscriptions removed.");
    }

    private async Task UnsubscribeResize()
    {
        if (_resizeSub is null) return;
        await _resizeSub.DisposeAsync();
        _resizeSub = null;
    }

    private async Task UnsubscribeScroll()
    {
        if (_scrollSub is null) return;
        await _scrollSub.DisposeAsync();
        _scrollSub = null;
    }

    public async ValueTask DisposeAsync()
    {
        await UnsubscribeResize();
        await UnsubscribeScroll();
        await visualViewport.DisposeAsync();
    }
}
