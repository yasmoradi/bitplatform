@page "/userAgent"
@inject Bit.Butil.UserAgent userAgent

<PageTitle>Butil - UserAgent Samples</PageTitle>

<PageHeader Category="Browser & Device"
            Title="UserAgent"
            Lead="Parse a user-agent string into structured details - browser, engine, OS and device - without writing a single regex."
            MdnUrl="https://developer.mozilla.org/en-US/docs/Web/API/Navigator/userAgent" />

<pre>
@@inject Bit.Butil.UserAgent userAgent

var props = await userAgent.Extract();          // current browser
var props2 = await userAgent.Extract(uaString);  // a specific string
</pre>

<div class="stack" style="margin-top:1.5rem">
    <DemoCard Title="Extract user-agent details" Api="Extract"
              Description="Leave the field empty to parse the current browser's user-agent, or paste any user-agent string to parse it.">
        <div class="field">
            <span class="field-label">User-agent string (optional)</span>
            <input @bind="userAgentString" placeholder="Leave empty for the current browser" />
        </div>
        <button @onclick="Extract">Extract</button>
    </DemoCard>

    <DemoCard Title="UA Client Hints" Api="GetBrands / GetHighEntropyValues / …"
              Description="Modern browsers expose structured user-agent data via navigator.userAgentData.">
        <div class="controls">
            <button @onclick="ClientHintsSupported">IsClientHintsSupported</button>
            <button @onclick="GetBrands">GetBrands</button>
            <button @onclick="IsMobile">IsMobile</button>
            <button @onclick="GetPlatform">GetPlatform</button>
            <button @onclick="GetHighEntropy">GetHighEntropyValues</button>
        </div>
    </DemoCard>
</div>

<DemoConsole @ref="output" Title="userAgent output" />

@code {
    private DemoConsole output = default!;
    private string? userAgentString;

    private async Task Extract()
    {
        var props = await userAgent.Extract(userAgentString);
        await output.Success("UserAgent properties →", props);
    }

    private async Task ClientHintsSupported()
    {
        await output.Success("IsClientHintsSupported →", await userAgent.IsClientHintsSupported());
    }

    private async Task GetBrands()
    {
        var brands = await userAgent.GetBrands();
        await output.Success("GetBrands →", brands.Length == 0 ? "(empty - UA-CH unsupported)" : brands);
    }

    private async Task IsMobile()
    {
        await output.Success("IsMobile →", await userAgent.IsMobile());
    }

    private async Task GetPlatform()
    {
        await output.Success("GetPlatform →", await userAgent.GetPlatform());
    }

    private async Task GetHighEntropy()
    {
        var values = await userAgent.GetHighEntropyValues("architecture", "platformVersion", "model", "uaFullVersion");
        await output.Success("GetHighEntropyValues →", values);
    }
}
