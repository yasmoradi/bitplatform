@page "/navigator"
@inject Bit.Butil.Navigator navigator

<PageTitle>Butil - Navigator Samples</PageTitle>

<PageHeader Category="Browser & Device"
            Title="Navigator"
            Lead="Query the user agent environment: hardware, languages, connectivity and capabilities - plus actions like sharing, vibrating and app badges."
            MdnUrl="https://developer.mozilla.org/en-US/docs/Web/API/Navigator" />

<pre>
@@inject Bit.Butil.Navigator navigator

var userAgent = await navigator.GetUserAgent();
await navigator.Share(new ShareData { title = "Bit.Butil", url = "https://bitplatform.dev" });
</pre>

<div class="stack" style="margin-top:1.5rem">
    <DemoCard Title="Device & environment" Api="GetDeviceMemory / GetHardwareConcurrency / ..."
              Description="Read-only properties describing the device and browser.">
        <div class="controls">
            <button @onclick="@GetDeviceMemory">DeviceMemory</button>
            <button @onclick="@GetHardwareConcurrency">HardwareConcurrency</button>
            <button @onclick="@GetMaxTouchPoints">MaxTouchPoints</button>
            <button @onclick="@GetLanguage">Language</button>
            <button @onclick="@GetLanguages">Languages</button>
            <button @onclick="@GetUserAgent">UserAgent</button>
        </div>
    </DemoCard>

    <DemoCard Title="Capabilities & status" Api="IsOnLine / IsPdfViewerEnabled / ..."
              Description="Boolean checks for connectivity and feature support.">
        <div class="controls">
            <button @onclick="@GetIsOnLine">IsOnLine</button>
            <button @onclick="@GetIsPdfViewerEnabled">IsPdfViewerEnabled</button>
            <button @onclick="@GetIsWebDriver">IsWebDriver</button>
            <button @onclick="@GetCanShare">CanShare</button>
        </div>
    </DemoCard>

    <DemoCard Title="Share" Api="Share"
              Description="Invoke the native share sheet (where supported).">
        <div class="field">
            <span class="field-label">Title</span>
            <input @bind-value="titleValue" placeholder="Share title" />
        </div>
        <div class="field">
            <span class="field-label">Text</span>
            <input @bind-value="textValue" placeholder="Share text" />
        </div>
        <div class="field">
            <span class="field-label">URL</span>
            <input @bind-value="urlValue" placeholder="https://..." />
        </div>
        <button @onclick="Share">Share</button>
    </DemoCard>

    <DemoCard Title="App badge & beacon" Api="SetAppBadge / ClearAppBadge / SendBeacon"
              Description="Set or clear the PWA app icon badge and send a fire-and-forget beacon.">
        <div class="controls">
            <button @onclick="@SetBadge">SetAppBadge</button>
            <button class="secondary" @onclick="@ClearBadge">ClearAppBadge</button>
            <button class="secondary" @onclick="@SendBeacon">SendBeacon</button>
        </div>
    </DemoCard>

    <DemoCard Title="Vibrate" Api="Vibrate"
              Description="Vibrate the device with an SOS pattern (mobile only).">
        <button @onclick="@Vibrate">Vibrate (SOS)</button>
    </DemoCard>
</div>

<DemoConsole @ref="output" Title="navigator output" />

@code {
    private DemoConsole output = default!;

    private string textValue;
    private string titleValue;
    private string urlValue;

    private int[] sosPattern = [100, 30, 100, 30, 100, 30, 200, 30, 200, 30, 200, 30, 100, 30, 100, 30, 100];

    private async Task GetDeviceMemory()
    {
        var result = await navigator.GetDeviceMemory();
        await output.Success("DeviceMemory → 2 ^", result);
    }

    private async Task GetHardwareConcurrency()
    {
        await output.Success("HardwareConcurrency →", await navigator.GetHardwareConcurrency());
    }

    private async Task GetLanguage()
    {
        await output.Success("Language →", await navigator.GetLanguage());
    }

    private async Task GetLanguages()
    {
        await output.Success("Languages →", string.Join(", ", await navigator.GetLanguages()));
    }

    private async Task GetMaxTouchPoints()
    {
        await output.Success("MaxTouchPoints →", await navigator.GetMaxTouchPoints());
    }

    private async Task GetIsOnLine()
    {
        await output.Success("IsOnLine →", await navigator.IsOnLine());
    }

    private async Task GetIsPdfViewerEnabled()
    {
        await output.Success("IsPdfViewerEnabled →", await navigator.IsPdfViewerEnabled());
    }

    private async Task GetUserAgent()
    {
        await output.Success("UserAgent →", await navigator.GetUserAgent());
    }

    private async Task GetCanShare()
    {
        await output.Success("CanShare →", await navigator.CanShare());
    }

    private async Task GetIsWebDriver()
    {
        await output.Success("IsWebDriver →", await navigator.IsWebDriver());
    }

    private async Task Share()
    {
        var shareData = new ShareData()
        {
            Text = textValue,
            title = titleValue,
            url = urlValue
        };

        await navigator.Share(shareData);
        await output.Log("Share invoked");
    }

    private async Task SetBadge()
    {
        await navigator.SetAppBadge();
        await output.Log("AppBadge set");
    }

    private async Task ClearBadge()
    {
        await navigator.ClearAppBadge();
        await output.Log("AppBadge cleared");
    }

    private async Task SendBeacon()
    {
        // sendBeacon issues an HTTP POST. The target must accept POST requests,
        // so we use a public echo endpoint here (the static demo host has no backend).
        var queued = await navigator.SendBeacon("https://postman-echo.com/post", "butil-demo-beacon");
        await output.Success("Beacon queued →", queued);
    }

    private async Task Vibrate()
    {
        await navigator.Vibrate(sosPattern);
        await output.Log("Vibrate triggered");
    }
}
