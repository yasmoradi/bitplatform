@page "/document"
@implements IDisposable
@inject Bit.Butil.Document document

<PageTitle>Butil - Document Samples</PageTitle>

<PageHeader Category="DOM"
            Title="Document"
            Lead="Inspect and control the current document: read metadata, toggle design mode and direction, attach DOM event listeners and change the page title."
            MdnUrl="https://developer.mozilla.org/en-US/docs/Web/API/Document" />

<pre>
@@inject Bit.Butil.Document document

await document.AddEventListener(ButilEvents.Click, args => { ... });
await document.SetTitle("New shiny title");
</pre>

<div class="stack" style="margin-top:1.5rem">
    <DemoCard Title="Document click listener" Api="AddEventListener / RemoveEventListener"
              Description="Register a C# handler for document clicks. While registered, every click anywhere logs its coordinates below.">
        <div class="controls">
            <button @onclick=AddEventListener disabled="@isRegistered">Add listener</button>
            <button class="secondary" @onclick=RemoveEventListener disabled="@(!isRegistered)">Remove listener</button>
            <span class="result-pill">Registered: <b>@isRegistered</b></span>
        </div>
    </DemoCard>

    <DemoCard Title="Document metadata" Api="GetCharacterSet / GetContentType / ..."
              Description="Read read-only properties of the document.">
        <div class="controls">
            <button @onclick=GetCharacterSet>Character set</button>
            <button @onclick=GetContentType>Content type</button>
            <button @onclick=GetCompatMode>Compat mode</button>
            <button @onclick=GetReferrer>Referrer</button>
            <button @onclick=GetDocumentURI>Document URI</button>
            <button @onclick=GetUrl>URL</button>
        </div>
    </DemoCard>

    <DemoCard Title="Design mode" Api="SetDesignMode / GetDesignMode"
              Description="When design mode is on, the whole page becomes editable.">
        <div class="check-row">
            <input type="checkbox" @bind="@isDesignModeOn" id="dm" />
            <label for="dm">@(isDesignModeOn ? "On" : "Off")</label>
        </div>
        <div class="controls">
            <button @onclick=SetDesignMode>Set design mode</button>
            <button class="secondary" @onclick=GetDesignMode>Get design mode</button>
        </div>
    </DemoCard>

    <DemoCard Title="Text direction" Api="SetDir / GetDir"
              Description="Switch the document between left-to-right and right-to-left.">
        <div class="check-row">
            <input type="checkbox" @bind="@isDocumentDirRtl" id="dir" />
            <label for="dir">@(isDocumentDirRtl ? "Rtl" : "Ltr")</label>
        </div>
        <div class="controls">
            <button @onclick=SetDocumentDir>Set dir</button>
            <button class="secondary" @onclick=GetDocumentDir>Get dir</button>
        </div>
    </DemoCard>

    <DemoCard Title="Document title" Api="SetTitle / GetTitle"
              Description="Change the browser tab title and read it back.">
        <div class="field">
            <span class="field-label">Title</span>
            <input @bind-value="documentTitle" placeholder="New document title" />
        </div>
        <div class="controls">
            <button @onclick=SetTitle>Set title</button>
            <button class="secondary" @onclick=GetTitle>Get title</button>
        </div>
    </DemoCard>
</div>

<DemoConsole @ref="output" Title="document output" />

@code {
    private DemoConsole output = default!;
    private bool isRegistered = false;

    private Action<ButilMouseEventArgs> _handler = default!;

    private string documentTitle;

    private bool isDesignModeOn;

    private bool isDocumentDirRtl;

    protected override void OnInitialized()
    {
        _handler = (ButilMouseEventArgs arg) => _ = output.Info("Click from C# → X:", arg.ClientX, "Y:", arg.ClientY);

        base.OnInitialized();
    }

    private void AddEventListener()
    {
        _ = document.AddEventListener(ButilEvents.Click, _handler);
        isRegistered = true;
    }

    private void RemoveEventListener()
    {
        _ = document.RemoveEventListener(ButilEvents.Click, _handler);
        isRegistered = false;
    }

    private async Task GetCharacterSet()
    {
        await output.Success("document.characterSet →", await document.GetCharacterSet());
    }

    private async Task GetCompatMode()
    {
        await output.Success("document.compatMode →", await document.GetCompatMode());
    }

    private async Task GetContentType()
    {
        await output.Success("document.contentType →", await document.GetContentType());
    }

    private async Task GetReferrer()
    {
        var res = await document.GetReferrer();

        if (string.IsNullOrWhiteSpace(res) is false)
        {
            await output.Success("The user came from →", res);
        }
        else
        {
            await output.Info("The user landed directly on this page");
        }
    }

    private async Task GetUrl()
    {
        await output.Success("document.URL →", await document.GetUrl());
    }

    private async Task GetDocumentURI()
    {
        await output.Success("document.documentURI →", await document.GetDocumentURI());
    }

    private async Task SetDesignMode()
    {
        await document.SetDesignMode(isDesignModeOn ? DesignMode.On : DesignMode.Off);
        await output.Log("document.designMode set to", isDesignModeOn ? "On" : "Off");
    }

    private async Task GetDesignMode()
    {
        await output.Success("document.designMode →", await document.GetDesignMode());
    }

    private async Task SetDocumentDir()
    {
        await document.SetDir(isDocumentDirRtl ? DocumentDir.Rtl : DocumentDir.Ltr);
        await output.Log("document.dir set to", isDocumentDirRtl ? "Rtl" : "Ltr");
    }

    private async Task GetDocumentDir()
    {
        await output.Success("document.dir →", await document.GetDir());
    }

    private async Task SetTitle()
    {
        await document.SetTitle(documentTitle);
        await output.Log("document.title set to", $"\"{documentTitle}\"");
    }

    private async Task GetTitle()
    {
        await output.Success("document.title →", await document.GetTitle());
    }

    public void Dispose()
    {
        if (isRegistered)
        {
            _ = document.RemoveEventListener(ButilEvents.Click, _handler);
        }
    }
}
