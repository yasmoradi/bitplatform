@page "/screen"
@implements IAsyncDisposable
@inject Bit.Butil.Screen screen

<PageTitle>Butil - Screen Samples</PageTitle>

<PageHeader Category="Browser & Device"
            Title="Screen"
            Lead="Read the physical screen's dimensions, available area and color depth. A change listener is registered, so resizing logs the new dimensions automatically."
            MdnUrl="https://developer.mozilla.org/en-US/docs/Web/API/Screen" />

<pre>
@@inject Bit.Butil.Screen screen

var width  = await screen.GetWidth();
var height = await screen.GetHeight();
</pre>

<div class="stack" style="margin-top:1.5rem">
    <DemoCard Title="Dimensions" Api="GetWidth / GetHeight / GetAvailable*"
              Description="Total screen size versus the area available to windows (excluding OS bars).">
        <div class="controls">
            <button @onclick=GetWidth>Width</button>
            <button @onclick=GetHeight>Height</button>
            <button @onclick=GetAvailableWidth>AvailableWidth</button>
            <button @onclick=GetAvailableHeight>AvailableHeight</button>
        </div>
    </DemoCard>

    <DemoCard Title="Color & extended" Api="GetColorDepth / GetPixelDepth / IsExtended"
              Description="Color/pixel depth in bits, and whether the desktop spans multiple displays.">
        <div class="controls">
            <button @onclick=GetColorDepth>ColorDepth</button>
            <button @onclick=GetPixelDepth>PixelDepth</button>
            <button @onclick=GetIsExtended>IsExtended</button>
        </div>
    </DemoCard>
</div>

<DemoConsole @ref="output" Title="screen output" />

@code {
    private DemoConsole output = default!;

    protected override async Task OnInitializedAsync()
    {
        await screen.AddChange(() => _ = GetScreenDimensions());
        await base.OnInitializedAsync();
    }

    private async Task GetScreenDimensions()
    {
        var width = await screen.GetWidth();
        var height = await screen.GetHeight();
        await output.Info("Screen changed →", width, "x", height);
    }

    private async Task GetAvailableHeight()
    {
        await output.Success("screen.availHeight →", await screen.GetAvailableHeight());
    }

    private async Task GetAvailableWidth()
    {
        await output.Success("screen.availWidth →", await screen.GetAvailableWidth());
    }

    private async Task GetHeight()
    {
        await output.Success("screen.height →", await screen.GetHeight());
    }

    private async Task GetWidth()
    {
        await output.Success("screen.width →", await screen.GetWidth());
    }

    private async Task GetColorDepth()
    {
        await output.Success("screen.colorDepth →", await screen.GetColorDepth());
    }

    private async Task GetPixelDepth()
    {
        await output.Success("screen.pixelDepth →", await screen.GetPixelDepth());
    }

    private async Task GetIsExtended()
    {
        await output.Success("screen.isExtended →", await screen.IsExtended());
    }

    public async ValueTask DisposeAsync()
    {
        await screen.DisposeAsync();
    }
}
