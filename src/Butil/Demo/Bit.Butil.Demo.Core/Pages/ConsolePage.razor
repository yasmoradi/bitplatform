@page "/console"
@inject Bit.Butil.Console console

<PageTitle>Butil - Console Samples</PageTitle>

<PageHeader Category="Utilities"
            Title="Console"
            Lead="A full C# mirror of the browser console: log levels, assertions, counters, timers, groups, tables and profiling. Open your DevTools console (F12) to see the output."
            MdnUrl="https://developer.mozilla.org/en-US/docs/Web/API/console" />

<pre>
@@inject Bit.Butil.Console console

await console.Log("This is a test log");
await console.Table(new { Name = "Value", Value = value });
</pre>

<DemoCard Title="Shared value" Api="value"
          Description="Most buttons below send this value to the console. Edit it and watch how each console method renders it in DevTools.">
    <div class="field">
        <span class="field-label">Value</span>
        <input @bind-value="value" @ref="inputRef" />
    </div>
</DemoCard>

<div class="stack">
    <DemoCard Title="Log levels" Api="Log / Info / Warn / Error / Debug"
              Description="The five standard severity levels, each styled differently in DevTools.">
        <div class="controls">
            <button @onclick="@(() => console.Log("This is a test log:", value))">Log</button>
            <button @onclick="@(() => console.Info("This is a test info:", value))">Info</button>
            <button @onclick="@(() => console.Warn("This is a test warn:", value))">Warn</button>
            <button @onclick="@(() => console.Error("This is a test error:", value))">Error</button>
            <button @onclick="@(() => console.Debug(value))">Debug</button>
        </div>
    </DemoCard>

    <DemoCard Title="Inspect & assert" Api="Dir / Dirxml / Assert / Table"
              Description="Inspect DOM nodes, assert conditions and render objects as a table.">
        <div class="controls">
            <button @onclick="@(() => console.Dir(inputRef))">Dir</button>
            <button @onclick="@(() => console.Dirxml(inputRef))">Dirxml</button>
            <button @onclick="@(() => console.Assert(false, "This is a test assert:", value))">Assert</button>
            <button @onclick="@(() => console.Table(new { Name = "Value", Value = value }))">Table</button>
        </div>
    </DemoCard>

    <DemoCard Title="Counters" Api="Count / CountReset"
              Description="Count how many times a label has been logged, then reset it.">
        <div class="controls">
            <button @onclick="@(() => console.Count(value))">Count</button>
            <button class="secondary" @onclick="@(() => console.CountReset(value))">CountReset</button>
        </div>
    </DemoCard>

    <DemoCard Title="Timers" Api="Time / TimeLog / TimeEnd / TimeStamp"
              Description="Start a timer, log elapsed time, then end it.">
        <div class="controls">
            <button @onclick="@(() => console.Time(value))">Time</button>
            <button @onclick="@(() => console.TimeLog(value))">TimeLog</button>
            <button @onclick="@(() => console.TimeEnd(value))">TimeEnd</button>
            <button @onclick="@(() => console.TimeStamp(value))">TimeStamp</button>
        </div>
    </DemoCard>

    <DemoCard Title="Groups" Api="Group / GroupCollapsed / GroupEnd"
              Description="Create nested, collapsible groups of log entries.">
        <button @onclick="CreateGroupLogs">Create grouped logs</button>
    </DemoCard>

    <DemoCard Title="Profiling & trace" Api="Profile / Trace"
              Description="Start/stop a performance profile and print a stack trace.">
        <div class="controls">
            <button @onclick="@(() => console.Profile(value))">Profile</button>
            <button @onclick="@(() => console.ProfileEnd(value))">ProfileEnd</button>
            <button class="secondary" @onclick="@(() => console.Trace(value))">Trace</button>
        </div>
    </DemoCard>

    <DemoCard Title="Clear" Api="Clear"
              Description="Wipe the DevTools console.">
        <button class="danger" @onclick="@(() => console.Clear())">Clear console</button>
    </DemoCard>
</div>

@code {
    private string value = "Test";

    private ElementReference inputRef;

    private async Task CreateGroupLogs()
    {
        await console.Log("This is the outer level");
        await console.Group();
        await console.Log("Level 2");
        await console.Group();
        await console.Log("Level 3");
        await console.Warn("More of level 3");
        await console.GroupCollapsed();
        await console.Log("Back to level 2");
        await console.GroupEnd();
        await console.Log("Back to the outer level");
    }
}
