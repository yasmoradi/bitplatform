@page "/notification"
@inject Bit.Butil.Notification notification

<PageTitle>Butil - Notification Samples</PageTitle>

<PageHeader Category="Utilities"
            Title="Notification"
            Lead="Request permission and show native system notifications from C#. The browser will prompt for permission the first time you show one."
            MdnUrl="https://developer.mozilla.org/en-US/docs/Web/API/Notification" />

<pre>
@@inject Bit.Butil.Notification notification

var permission = await notification.RequestPermission();
await notification.Show("title", new() { Body = "this is the body" });
</pre>

<div class="stack" style="margin-top:1.5rem">
    <DemoCard Title="Permission" Api="GetPermission / RequestPermission"
              Description="Check the current notification permission or prompt the user for it.">
        <div class="controls">
            <button @onclick="GetPermission">Get permission</button>
            <button class="secondary" @onclick="RequestPermission">Request permission</button>
            <span class="result-pill">Status: <b>@permissionStatus</b></span>
        </div>
    </DemoCard>

    <DemoCard Title="Show a notification" Api="Show"
              Description="Display a system notification with a title and body.">
        <div class="field">
            <span class="field-label">Title</span>
            <input @bind=@notifTitle placeholder="Notification title" />
        </div>
        <div class="field">
            <span class="field-label">Body</span>
            <textarea @bind=@notifBody placeholder="Notification body"></textarea>
        </div>
        <button @onclick="Show">Show notification</button>
    </DemoCard>
</div>

<DemoConsole @ref="output" Title="notification output" />

@code {
    private DemoConsole output = default!;
    private string notifTitle;
    private string notifBody;
    private string permissionStatus = "unknown";

    private async Task GetPermission()
    {
        var permission = await notification.GetPermission();
        permissionStatus = permission.ToString();
        await output.Success("Notification permission →", permissionStatus);
    }

    private async Task RequestPermission()
    {
        var permission = await notification.RequestPermission();
        permissionStatus = permission.ToString();
        await output.Success("Notification permission →", permissionStatus);
    }

    private async Task Show()
    {
        await notification.Show(notifTitle, new() { Body = notifBody });
        await output.Log("Show →", $"\"{notifTitle}\"");
    }
}
