@inherits LayoutComponentBase

<div class="page">
    <NavMenu @ref="_navMenu" />

    <div class="app-content">
        <div class="topbar">
            <button type="button" class="menu-btn" aria-label="Open navigation menu" @onclick="ToggleNav">☰</button>
            <span class="title">Bit.Butil Demo</span>
        </div>

        <main>
            <article>
                @Body
            </article>
        </main>
    </div>
</div>

@code {
    private NavMenu? _navMenu;

    private void ToggleNav() => _navMenu?.Toggle();
}
