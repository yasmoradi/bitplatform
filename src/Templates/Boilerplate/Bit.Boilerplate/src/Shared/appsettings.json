            "SendDefaultPii": true,
            "TracesSampleRate": 1.0,
            "EnableScopeSync": true,
            "AutoSessionTracking": true,
            "LogLevel": {
                "Default": "Warning",
                "Microsoft.Hosting.Lifetime": "Information",
                "Boilerplate.Client.Core.Services.AuthManager": "Information",
