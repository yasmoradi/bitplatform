@*+:cnd:noEmit*@
@attribute [Route(PageUrls.Dashboard)]
@attribute [Route("{culture?}" + PageUrls.Dashboard)]
@attribute [Authorize(Policy = AuthPolicies.PRIVILEGED_ACCESS)]
@*#if (multitenant == true)*@
@attribute [Authorize(Policy = AuthPolicies.TENANT_SELECTED)]
@*#endif*@
@attribute [Authorize(Policy = AppFeatures.AdminPanel.Dashboard_View)]
@inherits AppPageBase

<AppPageData Title="@Localizer[nameof(AppStrings.Dashboard)]"
             SubTitle="@Localizer[nameof(AppStrings.DashboardSubtitle)]"
             PageTitle="@Localizer[nameof(AppStrings.DashboardPageTitle)]" />

<section>
    <BitStack Gap="3rem">
        <OverallStatsWidget />

        <BitStack Horizontal Wrap FillContent>
            <ProductsCountPerCategoryWidget />
            <ProductsPercentageWidget />
        </BitStack>

    </BitStack>
</section>

